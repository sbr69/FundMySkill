# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_GENERATION_MODEL=gemini-2.0-flash-lite

# Pinecone
PINECONE_API_KEY=test_key
PINECONE_INDEX_NAME=rag-chatbot

# Firebase (project_id auto-extracted from credentials file)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# RAG Settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=8

# App Settings
DEBUG=true
CORS_ORIGINS=["*"]
